generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("ko")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}
